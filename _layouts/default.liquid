<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>

<link rel="icon" type="image/x-icon" href="{{ site.baseurl }}/favicon.ico">
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}

<script>
  // 检查当前会话是否已经登录过
  if (!sessionStorage.getItem("site_unlocked")) {
    var my_password = "xsceric11"; 
    var user_input = prompt("🔒 欢迎来到 xsceric.com！本站为私人学术主页，请输入访问密码：");
    
    if (user_input === my_password) {
      // 密码正确，发一个“通行证”存入浏览器
      sessionStorage.setItem("site_unlocked", "true");
    } else {
      // 密码错误，清空网页并拦截
      document.write("<div style='text-align:center; margin-top:100px; font-family: Arial, sans-serif;'><h2>⛔ 密码错误，无权访问本站。</h2><p>请刷新页面重试。</p></div>");
      window.stop(); 
    }
  }
</script>

  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
<div style="text-align: center; margin-top: 10px; color: #888; font-size: 14px;">
  <i class="fa-solid fa-eye"></i> 本站总访问量 <span id="busuanzi_value_site_pv"></span> 次
</div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
