<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    <!-- ================= 全站防闪烁密码锁 开始 ================= -->
    <style id="site-lock-style">html { display: none !important; }</style>
    <script>
      // ⚠️ 请在这里设置你的访问密码
      var SITE_PASSWORD = "xsceric11"; 
      
      if (sessionStorage.getItem("al_folio_unlocked") === "true") {
        // 如果已解锁，移除黑屋样式
        document.getElementById("site-lock-style").remove();
      } else {
        // 未解锁，弹出密码框
        var user_input = prompt("🔒 网站正在搭建与优化中，请输入访问密码：");
        if (user_input === SITE_PASSWORD) {
          sessionStorage.setItem("al_folio_unlocked", "true");
          document.getElementById("site-lock-style").remove();
        } else {
          // 密码错误，直接销毁页面 DOM 并替换为错误提示
          document.documentElement.innerHTML = `
            <head>
              <meta charset="utf-8">
              <title>⛔ 访问受限</title>
            </head>
            <body style="background:#f4f6f8; display:flex; justify-content:center; align-items:center; height:100vh; margin:0; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
              <div style="background:white; padding:40px; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.05); text-align:center;">
                <h2 style="color:#d9534f; margin-top:0;">⛔ 密码错误 / 访问被拒</h2>
                <p style="color:#666;">本站正在搭建与优化中，当前无权访问。<br>请刷新页面重新输入正确密码。</p>
              </div>
            </body>
          `;
          window.stop(); // 停止加载后续资源
        }
      }
    </script>
    <!-- ================= 全站防闪烁密码锁 结束 ================= -->

<link rel="icon" type="image/x-icon" href="{{ site.baseurl }}/favicon.ico">
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
<div style="text-align: center; margin-top: 10px; color: #888; font-size: 14px;">
  <i class="fa-solid fa-eye"></i> 本站总访问量 <span id="busuanzi_value_site_pv"></span> 次
</div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
